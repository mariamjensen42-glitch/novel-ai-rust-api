# AI Novel Writing API - 环境变量示例

# 服务
BIND_ADDR=127.0.0.1:8080

# 数据库
DATABASE_URL=sqlite://./data/novel.db

# 认证
JWT_SECRET=change-me-in-production
JWT_TTL_HOURS=72

# 限流
RATE_LIMIT_PER_MIN=60

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Qwen
QWEN_API_KEY=sk-your-qwen-key
QWEN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen-plus

# ----------------------------------------------------------------------------
# 可观测性（Observability）
# ----------------------------------------------------------------------------
# RUST_LOG 遵循 EnvFilter 语法：
#   info / debug / trace / warn / error
#   精细到模块：info,novel_ai_rust_api=debug,tower=warn
# 默认 info。生产环境推荐 info,novel_ai_rust_api=info,sqlx=warn
RUST_LOG=info

# RUST_LOG_FORMAT 控制 tracing 输出格式：
#   pretty —— 人类可读（开发默认）
#   json   —— 单行 JSON（接 Loki / Elasticsearch / Datadog）
RUST_LOG_FORMAT=pretty

# /metrics 端点（Prometheus 文本格式，无需鉴权，供 scrape）
# 路径在代码里硬编码为 GET /metrics

